# Pedir notas
nota1 = float(input("Ingrese nota 1: "))
nota2 = float(input("Ingrese nota 2: "))
nota3 = float(input("Ingrese nota 3: "))

# Calcular promedio
promedio = (nota1 + nota2 + nota3) / 3

# Mostrar notas
print("Nota 1:", nota1)
print("Nota 2:", nota2)
print("Nota 3:", nota3)

# Mostrar promedio
print("Promedio:", promedio)

# Comparar si aprobo
print("Aprobo?:", promedio >= 3)
